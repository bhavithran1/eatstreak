{
  "expo": {
    "name": "EatStreak",
    "slug": "eatstreak",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "eatstreak",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "EatStreak needs camera access to scan QR codes at restaurants."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0807",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow EatStreak to scan QR codes at restaurants."
        }
      ],
      "expo-font",
      "expo-splash-screen"
    ]
  }
}
